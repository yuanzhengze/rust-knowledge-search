# Optional AI/embedding configuration.
# Copy this file to .env when local development needs API access.
# Never commit the real .env file.

AI_API_KEY=your_api_key_here
AI_BASE_URL=https://example.com/v1
AI_EMBEDDING_MODEL=embedding-model-name
AI_CHAT_MODEL=chat-model-name

# Optional local index path.
KNOWLEDGE_INDEX_PATH=.knowledge_index.json
